    "@colyseus/ws-transport": "^0.16.5",
    "@types/express": "^5.0.6",
    "colyseus": "^0.16.5",
    "colyseus.js": "^0.16.22",
    "cors": "^2.8.5",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/node": "^20.19.27",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
